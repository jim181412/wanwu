stop-iam:
	docker compose -f docker-compose-develop.yaml \
		--env-file .env.image.${WANWU_ARCH} \
		--env-file .env \
		down iam-service

recompile-iam:
	make -f Makefile.develop stop-iam
	make -f Makefile.develop build-iam-amd64
	make -f Makefile.develop run-iam

